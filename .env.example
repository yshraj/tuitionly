# Copy to .env.local — never commit real secrets.

# Next.js app (required for npm run dev / build)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional: legacy script / Vite naming (check-phone-otp also reads these)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# --- Scripts only (never use in browser) ---
# Session pooler URI for npm run setup:db (IPv4-friendly on Windows).
# SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# TEST_PHONE=+918123456789

# Twilio is configured in Supabase Dashboard → Auth → Phone.
